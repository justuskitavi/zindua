// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Alert {
  id String @id @default(uuid()) @db.Uuid
  source String
  externalId String @map("external_id")
  title String 
  rawContent String @map("raw_content")
  hazardType String @map("hazard_type")
  severity String
  countryCode String @map("country_code")
  region String?
  issuedAt DateTime @map("issued_at") @db.Timestamptz
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()
  processed Boolean @default(false)
  translations Translation[]

  @@unique([source, externalId])
  @@map("alerts")
}

model Translation {
  id          String   @id @default(uuid()) @db.Uuid
  alertId     String   @map("alert_id") @db.Uuid
  language    String   // 'en' | 'sw' | 'so' | 'am' | 'om'
  smsContent  String   @map("sms_content")   // ≤160 chars — for Africa's Talking
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, language])  // one translation per language per alert`
  @@map("translations")
}